- **refactor:** Clean component APIs - all components now follow consistent `initAllComponents(root)` pattern

---

## ⚠️ **Breaking Changes & Migration**

### Before (v0.75.x):

```templ
@button.Button(button.Props{
    HxGet: "/api/endpoint",
    HxTrigger: "click",
}) { Click me }
```

### After (v0.76.0):

```templ
@button.Button(button.Props{
    Attributes: templ.Attributes{
        "hx-get": "/api/endpoint",
        "hx-trigger": "click",
    },
}) { Click me }
```

### Framework Integration Required:

#### HTMX Users:

```html
<script>
  // Re-initialize templUI components after HTMX swaps
  document.body.addEventListener("htmx:afterSwap", (e) => {
    if (window.templUI) {
      Object.values(window.templUI).forEach((comp) => {
        comp.initAllComponents?.(e.detail.elt);
      });
    }
  });

  // Re-initialize components after out-of-band swaps
  document.body.addEventListener("htmx:oobAfterSwap", (e) => {
    if (window.templUI) {
      Object.values(window.templUI).forEach((comp) => {
        comp.initAllComponents?.(e.detail.target);
      });
    }
  });

  // Optional: Cleanup before swap (for components with event listeners)
  document.body.addEventListener("htmx:beforeSwap", (e) => {
    if (window.templUI) {
      Object.values(window.templUI).forEach((comp) => {
        comp.cleanup?.(e.detail.target);
      });
    }
  });
</script>
```

#### Datastar Users:

```html
<script>
  // Re-initialize templUI components after Datastar fragment merges
  document.addEventListener("datastar-merge-fragments", (e) => {
    if (window.templUI) {
      Object.values(window.templUI).forEach((comp) => {
        comp.initAllComponents?.(document);
      });
    }
  });

  // Cleanup components when fragments are removed
  document.addEventListener("datastar-remove-fragments", (e) => {
    if (window.templUI) {
      Object.values(window.templUI).forEach((comp) => {
        comp.cleanup?.(document);
      });
    }
  });
</script>
```

---

